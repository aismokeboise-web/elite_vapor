#
# Server environment variables for admin emails and authentication
#

# --- SMTP configuration (required to send admin password reset / password-changed emails) ---

# Hostname of your SMTP server (e.g. smtp.sendgrid.net, smtp.gmail.com)
SMTP_HOST=smtp.example.com

# Port for SMTP (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP credentials
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# From address used for outgoing admin emails.
# If omitted, it falls back to no-reply@empirevaporcasper.com.
SMTP_FROM=no-reply@empirevaporcasper.com


# --- Base URL used when generating admin password reset links ---

# Preferred: origin where the React admin UI is served.
# The final link will be: <ADMIN_BASE_URL>/admin/reset-password?token=<JWT_TOKEN>
ADMIN_BASE_URL=http://localhost:5173

# Optional fallback if ADMIN_BASE_URL is not set.
# APP_BASE_URL=http://localhost:5173


# --- Admin JWT secrets (keep these private; do NOT commit real values) ---

# Secret used to sign admin auth tokens
ADMIN_JWT_SECRET=change-me-admin-jwt-secret

# Optional: separate secret used to sign admin password reset tokens.
# If omitted, the server falls back to ADMIN_JWT_SECRET.
#ADMIN_RESET_JWT_SECRET=change-me-admin-reset-secret

